rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /wordbooks/{userId} {
      
      allow read: if request.auth != null 
        && request.auth.uid == userId
        && userId.matches('^[a-zA-Z0-9_-]{3,40}$');

      allow write: if request.auth != null 
        && request.auth.uid == userId
        && userId.matches('^[a-zA-Z0-9_-]{3,40}$')
        && request.resource.data.keys().hasOnly(['dictionary', 'ownerId', 'passwordHash', 'updatedAt'])
        && request.resource.data.dictionary is map
        && request.resource.data.ownerId is string
        && request.resource.data.ownerId == userId
        && request.resource.data.passwordHash.matches('^[a-f0-9]{64}$')
        && (!exists(/databases/$(database)/documents/wordbooks/$(userId))
          || request.resource.data.passwordHash == resource.data.passwordHash)
        && request.resource.data.updatedAt is string;
    }
  }
}