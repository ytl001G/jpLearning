rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /wordbooks/{userId} {
      allow read: if userId.matches('^[a-zA-Z0-9_-]{3,40}$');
      allow write: if userId.matches('^[a-zA-Z0-9_-]{3,40}$')
        && request.resource.data.keys().hasOnly(['dictionary', 'updatedAt'])
        && request.resource.data.dictionary is map
        && request.resource.data.updatedAt is string;
    }
  }
}
